# ===== Warzone Services — Environment Variables =====
# On Railway: set these in the Variables tab. Locally: copy to .env

# REQUIRED — from https://discord.com/developers/applications (Bot tab)
DISCORD_TOKEN=your_discord_bot_token_here

# REQUIRED — password for the web control panel
PANEL_PASSWORD=change_me_strong

# OPTIONAL
# PORT=3000
# AUTO_SETUP=0   # set to 0 to disable automatic server organization on first boot
